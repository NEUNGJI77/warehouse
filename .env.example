# 서버 설정 (선택 사항 — 기본값 그대로 사용해도 됩니다)
PORT=5000
HOST=0.0.0.0

# 1로 설정하면 Flask 개발 서버 디버그 모드 활성화 (운영 시 0)
FLASK_DEBUG=0

# 세션 암호화 키: 운영 배포 시 반드시 긴 랜덤 문자열로 교체하세요
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=logistics-secret-2026

